# ONPU AI K2 Studio - Environment template
# Copy to .env or .env.local and set values. NEVER commit .env or .env.local.
# Load order: .env then .env.local (local overrides).

# Server
K2_HOST=0.0.0.0
K2_PORT=5000
K2_DEBUG=false
K2_MAX_CONTENT_MB=16

# Paths (optional; defaults relative to project root)
# K2_UPLOAD_DIR=
# K2_OUTPUT_DIR=
# K2_TEMP_DIR=

# MusicGen
MUSICGEN_MODEL=facebook/musicgen-medium
MUSICGEN_MAX_DURATION=30

# YuE (subprocess)
YUE_WORKSPACE=
# Example: YUE_WORKSPACE=/path/to/YuE
YUE_STAGE1_MODEL=m-a-p/YuE-s1-7B-anneal-en-cot
YUE_STAGE2_MODEL=m-a-p/YuE-s2-1B-general
YUE_MAX_NEW_TOKENS=3000
YUE_RUN_N_SEGMENTS=2
YUE_SUBPROCESS_TIMEOUT=600
YUE_CUDA_DEVICE=0
# YUE_SUBPROCESS_MAX_MEMORY_MB=

# Security / rate limit
K2_RATE_LIMIT_REQUESTS=60
K2_RATE_LIMIT_WINDOW_S=60
# Optional API key (if set, require X-API-Key or Authorization: Bearer <key>)
# K2_API_KEY=

# Metrics
K2_PROMETHEUS_ENABLED=false
K2_METRICS_PORT=9090

# Production: when 1, validate_install.py requires .env or .env.local to exist
# K2_PRODUCTION=0
